// WAP to add diagonal elements of a matrix
#include<stdio.h>
int main(){
    int a[3][3], sum=0;
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
        printf("enter %d %d element of array",i,j);
        scanf("%d",&a[i][j]);
        }
        
    }
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            if(i==j){
                sum=sum+a[i][j];
            }
        }
    }
    printf("sum of the diagonal elements is : %d", sum );
    return 0;
}
