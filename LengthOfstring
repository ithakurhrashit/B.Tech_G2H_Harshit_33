// WAP to find length of a string 
#include<stdio.h>
int main(){
    char s[100] ;
    int length=0;
    printf("enter a string \n ");
    gets(s);
    for(int i=0;i<100;i++){
        if(s[i]==NULL){
            length=i;
            break ;
        }
    }
    printf("the length of string is: %d",length );
    return 0 ;
}
