// WAP to find length of a string
#include<stdio.h>
int main(){
    int n,a[3][3],freq=0;
    printf("enter the element whose frequency we have to find");
    scanf("%d",&n);
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            printf("enter the %d%d element of array",i,j);
            scanf("%d",&a[i][j]);
        }
    }
    printf("enter the element whose fequency you wanna serch");
    scanf("%d",&n);
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            if(a[i][j]==n){
                freq++;
            }
        }
        
    }
    printf("the frequency of %d element is %d",n,freq);
        return 0 ;
    
}
